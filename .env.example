# ── Vercel KV ────────────────────────────────────────────
# Required for production (auto-injected by Vercel when KV is linked).
# Local dev: leave empty to use local data.json fallback.
KV_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── JWT ──────────────────────────────────────────────────
# Secret key for signing auth tokens.
# Production: generate with `openssl rand -hex 32` (min 32 chars).
JWT_SECRET=your-random-secret-here

# ── Encryption ────────────────────────────────────────────
# Salt used for AES-256-GCM encryption of stored API keys.
# Production: set a unique random value (min 16 chars).
# APP_CIPHER_SALT=cps-local-cipher-salt-do-not-use-in-production

# ── Server ───────────────────────────────────────────────
# Port for local dev (default 8090).
PORT=8090

# Allowed CORS origin. Comma-separated for multiple origins.
# Local dev: http://localhost:8090
# Production: https://carousel-studio-app.vercel.app
CORS_ORIGIN=http://localhost:8090

# ── Supabase Storage ─────────────────────────────────────
# Required for category image uploads.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=cardio_category_image
